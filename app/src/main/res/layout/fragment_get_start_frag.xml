<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Get_start_frag"
    android:backgroundTint="@color/text_button">


    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/get_start_fon" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/shadow_get_start" />

    <ImageView
        android:id="@+id/coffeesctipt_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="170dp"
        android:layout_marginLeft="100dp"
        android:src="@drawable/coffeescript_logo" />

    <Button
        android:id="@+id/button_start"
        android:layout_width="242dp"
        android:layout_height="53dp"
        android:layout_marginLeft="90dp"
        android:layout_marginTop="644dp"
        android:backgroundTint="@color/button_color"
        android:fontFamily="@font/poppins_bold"
        android:text="Get Started"
        android:textColor="@color/text_button"
        android:textSize="20dp"
        android:textStyle="bold"
        app:cornerRadius="10dp"/>




</FrameLayout>