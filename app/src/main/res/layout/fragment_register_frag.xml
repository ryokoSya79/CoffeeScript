<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Register_frag">

    <ImageView
        android:id="@+id/imageView5"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/login_fon"
        android:scaleType="centerCrop"/>

    <ImageView
        android:id="@+id/imageView11"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/shadow_login"
        android:scaleType="centerCrop"/>

    <ImageView
        android:id="@+id/imageView12"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/logo_non_text"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="94dp"/>

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_semibold"
        android:text="Register your Account"
        android:textSize="24dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="160dp"
        android:textColor="@color/white" />

    <EditText
        android:id="@+id/edit_text_fullName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="220dp"
        android:background="@drawable/back_edit_text"
        android:ems="10"
        android:fontFamily="@font/poppins_medium"
        android:hint="Full Name"
        android:paddingLeft="20dp"
        android:inputType="textEmailAddress"
        android:textColorHint="@color/text_edit"
        android:textSize="15dp"
        android:textColor="@color/text_edit"/>

    <EditText
        android:id="@+id/edit_text_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="290dp"
        android:background="@drawable/back_edit_text"
        android:ems="10"
        android:fontFamily="@font/poppins_medium"
        android:hint="E-mail Address"
        android:paddingLeft="20dp"
        android:inputType="textEmailAddress"
        android:textColorHint="@color/text_edit"
        android:textSize="15dp"
        android:textColor="@color/text_edit"/>

    <EditText
        android:id="@+id/edit_text_pass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="360dp"
        android:background="@drawable/back_edit_text"
        android:ems="10"
        android:fontFamily="@font/poppins_medium"
        android:hint="Password"
        android:paddingLeft="20dp"
        android:inputType="textEmailAddress"
        android:textColorHint="@color/text_edit"
        android:textSize="15dp"
        android:textColor="@color/text_edit"/>

    <EditText
        android:id="@+id/edit_text_confirm_pass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="430dp"
        android:background="@drawable/back_edit_text"
        android:ems="10"
        android:fontFamily="@font/poppins_medium"
        android:hint="Confirm Password"
        android:paddingLeft="20dp"
        android:inputType="textEmailAddress"
        android:textColorHint="@color/text_edit"
        android:textSize="15dp"
        android:textColor="@color/text_edit"/>

    <Button
        android:id="@+id/button_register"
        android:layout_width="350dp"
        android:layout_height="63dp"
        android:text="Register"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/text_button"
        android:backgroundTint="@color/button_color"
        android:textSize="20dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="515dp"
        app:cornerRadius="10dp"/>

    <ImageView
        android:id="@+id/imageView13"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/liner_regist"
        android:layout_gravity="center_horizontal"
        android:scaleType="centerCrop"
        android:layout_marginTop="610dp"/>

    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Or Register with"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="16dp"
        android:layout_marginTop="598dp"
        android:layout_gravity="center_horizontal"/>

    <ImageView
        android:id="@+id/imageView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/facebook_button"
        android:layout_marginTop="635dp"
        android:layout_marginLeft="20dp"/>

    <ImageView
        android:id="@+id/imageView9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/google_button"
        android:layout_marginTop="635dp"
        android:layout_marginLeft="149dp"/>

    <ImageView
        android:id="@+id/imageView10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/twitch_button"
        android:layout_marginTop="635dp"
        android:layout_marginLeft="272dp"/>

    <TextView
        android:id="@+id/already_acc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="16dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginRight="30dp"
        android:layout_marginTop="730dp"
        android:text="Already have an account ?" />

    <TextView
        android:id="@+id/login_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/button_color"
        android:fontFamily="@font/poppins_bold"
        android:textSize="16dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginLeft="110dp"
        android:layout_marginTop="730dp"
        android:text="Login" />


</FrameLayout>