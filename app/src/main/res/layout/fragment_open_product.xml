        android:layout_marginLeft="236dp"/>

    <TextView
        android:id="@+id/text_small_size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Small"
        android:fontFamily="@font/poppins_bold"
        android:textSize="14dp"
        android:textColor="@color/button_color"
        android:layout_marginTop="627dp"
        android:layout_marginLeft="38dp"/>

    <TextView
        android:id="@+id/text_medium_size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Medium"
        android:fontFamily="@font/poppins_bold"
        android:textSize="14dp"
        android:textColor="@color/white"
        android:layout_marginTop="627dp"
        android:layout_marginLeft="135dp"/>

    <TextView
        android:id="@+id/text_large_size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Large"
        android:fontFamily="@font/poppins_bold"
        android:textSize="14dp"
        android:textColor="@color/button_color"
        android:layout_marginTop="627dp"
        android:layout_marginLeft="276dp"/>

    <ImageView
        android:id="@+id/button_plus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/button_plus"
        android:layout_marginTop="672dp"
        android:layout_marginRight="144dp"
        android:layout_gravity="right"/>

    <TextView
        android:id="@+id/number_cols"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter_semibold"
        android:text="1"
        android:textSize="18dp"
        android:textColor="@color/white"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="677dp" />

    <ImageView
        android:id="@+id/button_minus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/button_minus"
        android:layout_marginTop="672dp"
        android:layout_marginLeft="144dp"
        android:layout_gravity="left"/>

    <Button
        android:id="@+id/button_add_cart"
        android:layout_width="278dp"
        android:layout_height="60dp"
        android:text="Add to cart"
        app:cornerRadius="10dp"
        android:backgroundTint="@color/button_color"
        android:textSize="18dp"
        android:fontFamily="@font/poppins_semibold"
        android:textColor="@color/description"
        android:layout_gravity="bottom"
        android:layout_marginBottom="18dp"
        android:layout_marginLeft="92dp"/>

    <TextView
        android:id="@+id/textView13"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="22dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="30dp"
        android:layout_marginLeft="23dp"/>

    <TextView
        android:id="@+id/open_product_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="20"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="22dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="30dp"
        android:layout_marginLeft="42dp"/>


</FrameLayout>