<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Open_product">


    <ImageView
        android:id="@+id/imageView19"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/top_back_open_product"
        android:scaleType="centerCrop"/>

    <ImageView
        android:id="@+id/imageView20"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:src="@drawable/back_open_product"
        android:scaleType="centerCrop"/>

    <TextView
        android:id="@+id/name_coffee_open_product"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Liberica Coffee"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/white"
        android:textSize="22dp"
        android:layout_marginTop="65dp"
        android:layout_gravity="center_horizontal"/>

    <ImageView
        android:id="@+id/back_button"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/back_button"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="70dp"/>

    <ImageView
        android:id="@+id/imageView24"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/liner_igridient"
        android:layout_marginTop="336dp"
        android:layout_gravity="center_horizontal"/>

    <TextView
        android:id="@+id/textView5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ingredients"
        android:textColor="@color/white"
        android:layout_marginTop="260dp"
        android:fontFamily="@font/poppins_bold"
        android:textSize="22dp"
        android:layout_gravity="center_horizontal"/>

    <ImageView
        android:id="@+id/none_igredients_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/none_igridient"
        android:layout_marginTop="356dp"
        android:layout_gravity="right"
        android:layout_marginRight="23dp"/>

    <ImageView
        android:id="@+id/back_ingredients"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/back_milk_ingradient"
        android:layout_marginTop="310dp"
        android:layout_gravity="center_horizontal"/>


    <ImageView
        android:id="@+id/image_ingredients"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/milk_logo"
        android:layout_marginTop="320dp"
        android:layout_gravity="center_horizontal"/>

    <ImageView
        android:id="@+id/back_ingredients_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/back_milk_ingradient"
        android:layout_marginTop="356dp"
        android:layout_gravity="right"
        android:layout_marginRight="23dp"/>


    <ImageView
        android:id="@+id/image_ingredients_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/milk_logo"
        android:layout_marginTop="366dp"
        android:layout_gravity="right"
        android:layout_marginRight="33dp"/>

    <ImageView
        android:id="@+id/none_igredients"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/none_igridient"
        android:layout_marginTop="356dp"
        android:layout_marginLeft="23dp"/>



    <ImageView
        android:id="@+id/lemon_igredients"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/lemon_igridient"
        android:layout_marginTop="356dp"
        android:layout_gravity="right"
        android:layout_marginRight="23dp"/>

    <ImageView
        android:id="@+id/lemon_igredients_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/lemon_igridient"
        android:layout_marginTop="356dp"
        android:layout_gravity="right"
        android:layout_marginRight="23dp"/>


    <TextView
        android:id="@+id/text_igredients"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Milk"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="16dp"
        android:layout_marginTop="380dp"
        android:layout_gravity="center_horizontal"/>

    <TextView
        android:id="@+id/textView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Coffee Size"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/white"
        android:textSize="22dp"
        android:layout_marginTop="440dp"
        android:layout_gravity="center_horizontal"/>

    <ImageView
        android:id="@+id/button_small_size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/button_small_size"
        android:layout_marginTop="543dp"
        android:layout_marginLeft="26dp"/>

    <ImageView
        android:id="@+id/button_medium_size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/button_medium_size_press"
