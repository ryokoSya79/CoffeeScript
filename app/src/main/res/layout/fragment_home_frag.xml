<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Home_frag"
    android:background="@color/text_button">




    <ImageView
        android:id="@+id/imageView14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:layout_marginLeft="20dp"
        android:src="@drawable/avatar_umo" />

    <TextView
        android:id="@+id/name_user"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="22dp"
        android:textColor="@color/white"
        android:layout_marginTop="50dp"
        android:layout_marginLeft="100dp"
        android:text="" />

    <TextView
        android:id="@+id/text_morning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_light"
        android:textSize="22dp"
        android:textColor="#E3E3E3"
        android:layout_marginTop="80dp"
        android:layout_marginLeft="100dp"
        android:text="Good Morning!" />

    <ImageView
        android:id="@+id/imageView17"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/add_home"
        android:layout_marginTop="133dp"
        android:scaleType="centerCrop"
        android:layout_marginRight="20dp"
        android:layout_marginLeft="20dp" />

    <ImageView
        android:id="@+id/imageView18"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/add_home_coffee"
        android:layout_marginTop="135dp"
        android:layout_gravity="right"
        android:layout_marginRight="30dp"/>




    <LinearLayout
        android:id="@+id/menu_text"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:layout_marginTop="300dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/text_hot_coffee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:fontFamily="@font/inter_semibold"
            android:text="Hot Coffees"
            android:textColor="@color/button_color"
            android:textSize="18dp" />

        <TextView
            android:id="@+id/text_ice_teas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:fontFamily="@font/inter_medium"
            android:text="Ice Teas"
            android:textColor="#F5F5F5"
            android:textSize="18dp" />

        <TextView
            android:id="@+id/text_hot_teas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:fontFamily="@font/inter_medium"
            android:text="Hot Teas"
            android:textColor="#F5F5F5"
            android:textSize="18dp" />

        <TextView
            android:id="@+id/text_bakery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:fontFamily="@font/inter_medium"
            android:text="Bakery"
            android:textColor="#F5F5F5"
            android:textSize="18dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="18dp"
        android:textColor="@color/white"
        android:layout_marginTop="156dp"
        android:layout_marginLeft="33dp"
        android:layout_marginRight="173dp"
        android:text="Get 20% Discount On your First Order!" />

    <TextView
        android:id="@+id/textView_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="33dp"
        android:layout_marginTop="220dp"
        android:layout_marginRight="193dp"
        android:fontFamily="@font/poppins"
        android:text="Lorem ipsum dolor sit amet consectetur. Vestibulum eget blandit mattis"
        android:textColor="@color/white"
        android:textSize="9dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rc_item_products"
        android:layout_width="match_parent"
        android:layout_height="396dp"
        android:layout_marginTop="345dp"
        android:layout_marginLeft="20dp" />


