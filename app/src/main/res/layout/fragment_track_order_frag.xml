        android:textSize="16dp"
        android:layout_marginTop="455dp"
        android:layout_marginLeft="155dp"/>

    <TextView
        android:id="@+id/text_deliverd_track_order"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="23 march, 2024, 04:36 PM"
        android:fontFamily="@font/poppins_light"
        android:textColor="@color/white"
        android:textSize="13dp"
        android:layout_marginTop="479dp"
        android:layout_marginLeft="155dp"/>

    <TextView
        android:id="@+id/title_way_track_order"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="On Your way"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="16dp"
        android:layout_marginTop="534dp"
        android:layout_marginLeft="155dp"/>

    <TextView
        android:id="@+id/text_way_track_order"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="23 march, 2024, 04:36 PM"
        android:fontFamily="@font/poppins_light"
        android:textColor="@color/white"
        android:textSize="13dp"
        android:layout_marginTop="558dp"
        android:layout_marginLeft="155dp"/>


    <TextView
        android:id="@+id/title_progress_track_order"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="In Progress"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="16dp"
        android:layout_marginTop="613dp"
        android:layout_marginLeft="155dp"/>

    <TextView
        android:id="@+id/text_progress_track_order"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="23 march, 2024, 04:36 PM"
        android:fontFamily="@font/poppins_light"
        android:textColor="@color/white"
        android:textSize="13dp"
        android:layout_marginTop="637dp"
        android:layout_marginLeft="155dp"/>

    <TextView
        android:id="@+id/title_placed_track_order"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Order placed"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="16dp"
        android:layout_marginTop="692dp"
        android:layout_marginLeft="155dp"/>

    <TextView
        android:id="@+id/text_placed_track_order"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="23 march, 2024, 04:36 PM"
        android:fontFamily="@font/poppins_light"
        android:textColor="@color/white"
        android:textSize="13dp"
        android:layout_marginTop="716dp"
        android:layout_marginLeft="155dp"/>



</FrameLayout>