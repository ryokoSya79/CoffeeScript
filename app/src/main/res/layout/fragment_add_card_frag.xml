<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Add_card_frag"
    android:background="@color/text_button">


    <TextView
        android:id="@+id/title_frag_add_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add card"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/white"
        android:textSize="22dp"
        android:layout_marginTop="35dp"
        android:layout_gravity="center_horizontal"/>

    <ImageView
        android:id="@+id/back_button_add_card"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/back_button"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="70dp"/>

    <ImageView
        android:id="@+id/imageView25"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="120dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/back_cards_data" />

    <TextView
        android:id="@+id/number_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0000 8974 2842 4328"
        android:fontFamily="@font/poppins_semibold"
        android:textColor="@color/white"
        android:textSize="24dp"
        android:layout_marginTop="192dp"
        android:layout_marginLeft="50dp"/>

    <TextView
        android:id="@+id/here_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Name Here"
        android:fontFamily="@font/poppins_semibold"
        android:textColor="@color/white"
        android:textSize="13dp"
        android:layout_marginTop="285dp"
        android:layout_marginLeft="50dp"/>

    <TextView
        android:id="@+id/date_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="28/22"
        android:fontFamily="@font/poppins_semibold"
        android:textColor="@color/white"
        android:textSize="13dp"
        android:layout_marginTop="285dp"
        android:layout_marginLeft="187dp"/>

    <TextView
        android:id="@+id/title_name_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Card Holder name"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="16dp"
        android:layout_marginTop="361dp"
        android:layout_marginLeft="30dp"/>

    <EditText
        android:id="@+id/editText_name_card"
        android:layout_width="348dp"
        android:layout_height="56dp"
        android:ems="10"
        android:background="@drawable/back_layout_edit_add_card"
        android:layout_gravity="center_horizontal"
        android:hint="Name"
        android:paddingLeft="20dp"
        android:layout_marginTop="387dp"
        android:textColorHint="@color/color_edit_card"
        android:inputType="textEmailAddress" />

    <TextView
        android:id="@+id/title_number_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Card Number"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="16dp"
        android:layout_marginTop="457dp"
        android:layout_marginLeft="30dp"/>

    <EditText
        android:id="@+id/editText_number_card"
        android:layout_width="348dp"
        android:layout_height="56dp"
        android:ems="10"
        android:background="@drawable/back_layout_edit_add_card"
        android:layout_gravity="center_horizontal"
        android:hint="0000 8974 2842 4328"
        android:paddingLeft="20dp"

        android:layout_marginTop="483dp"
        android:textColorHint="@color/color_edit_card"
        android:inputType="text|numberPassword" />

    <TextView
        android:id="@+id/title_exipy_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expiry"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="16dp"
        android:layout_marginTop="554dp"
        android:layout_marginLeft="30dp"/>

    <EditText
        android:id="@+id/editText_expiry"
        android:layout_width="170dp"
        android:layout_height="56dp"
        android:ems="10"
        android:background="@drawable/back_layout_edit_add_card"
        android:hint="28/22"
        android:paddingLeft="20dp"
        android:layout_marginTop="580dp"
        android:layout_marginLeft="22dp"
        android:textColorHint="@color/color_edit_card"
        android:inputType="textEmailAddress" />

    <TextView
        android:id="@+id/title_cvv_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expiry"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="16dp"
        android:layout_marginTop="554dp"
        android:layout_marginLeft="213dp"/>

    <EditText
        android:id="@+id/editText_cvv"
        android:layout_width="170dp"
        android:layout_height="56dp"
        android:ems="10"
        android:background="@drawable/back_layout_edit_add_card"
        android:hint="000"
        android:paddingLeft="20dp"
        android:layout_marginTop="580dp"
        android:layout_marginLeft="201dp"
        android:textColorHint="@color/color_edit_card"
        android:inputType="textEmailAddress" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_add_card_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/back_layout_items"
        android:textAllCaps="false"
        android:layout_marginRight="30dp"
        android:layout_marginLeft="32dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="25dp"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="18dp"
        android:text="ADD CARD" />

</FrameLayout>