<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Setting_frag"
    android:background="@color/white">

    <View
        android:id="@+id/background_view_order"
        android:layout_width="match_parent"
        android:layout_height="131dp"
        android:layout_gravity="top"
        android:background="@drawable/back_button_top_setting" />

    <TextView
        android:id="@+id/title_frag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Setting"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/white"
        android:textSize="22dp"
        android:layout_marginTop="60dp"
        android:layout_gravity="center_horizontal"/>

    <ImageView
        android:id="@+id/back_button_setting"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/back_button"
        android:layout_marginLeft="30dp"
        android:layout_marginTop="65dp"/>

    <View
        android:id="@+id/button_view_password_manager"
        android:layout_width="350dp"
        android:layout_height="74dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="160dp"
        android:background="@drawable/back_button_setting" />

    <ImageView
        android:id="@+id/strekla_password_manager"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="188dp"
        android:layout_gravity="right"
        android:layout_marginRight="30dp"
        android:src="@drawable/icon_strelka" />

    <ImageView
        android:id="@+id/icon_password_manager"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="160dp"
        android:layout_marginLeft="30dp"
        android:src="@drawable/icon_password_manager" />

    <TextView
        android:id="@+id/title_password_manager"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Password Manager"
        android:fontFamily="@font/poppins_semibold"
        android:textColor="@color/black"
        android:textSize="20dp"
        android:layout_marginTop="183dp"
        android:layout_marginLeft="120dp"/>

    <ImageView
        android:id="@+id/imageView42"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="245dp"
        android:src="@drawable/line_setting" />

    <View
        android:id="@+id/button_view_delete"
        android:layout_width="350dp"
        android:layout_height="74dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="258dp"
        android:background="@drawable/back_button_setting" />

    <ImageView
        android:id="@+id/imageView44"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="286dp"
        android:layout_gravity="right"
        android:layout_marginRight="30dp"
        android:src="@drawable/icon_strelka" />

    <ImageView
        android:id="@+id/icon_delete_acc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="258dp"
        android:layout_marginLeft="30dp"
        android:src="@drawable/icon_delete_account" />

    <TextView
        android:id="@+id/title_delete_acc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delete Account"
        android:fontFamily="@font/poppins_semibold"
        android:textColor="@color/black"
        android:textSize="20dp"
        android:layout_marginTop="280dp"
        android:layout_marginLeft="120dp"/>

    <ImageView
        android:id="@+id/shadow_setting"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/shadow_password"
        android:scaleType="centerCrop"/>

    <FrameLayout
        android:id="@+id/change_password_fragment"
        android:layout_width="322dp"
        android:layout_height="335dp"
        android:background="@drawable/back_button_checkout"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="160dp">

        <TextView
            android:id="@+id/title_password_slip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сhange Password"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/white"
            android:textSize="22dp"
            android:layout_marginTop="23dp"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:id="@+id/title_old_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your old password"
            android:fontFamily="@font/poppins_medium"
            android:textColor="@color/white"
            android:textSize="16dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="66dp" />

        <EditText
            android:id="@+id/edit_old_password"
            android:layout_width="282dp"
            android:layout_height="56dp"
            android:ems="10"
            android:background="@drawable/back_button_profile"
            android:inputType="textPassword"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="94dp"
            android:hint="Old password"
            android:textColorHint="@color/gost"
            android:paddingLeft="20dp"
            android:textSize="14dp"
            android:textColor="@color/gost"
            android:fontFamily="@font/poppins_medium"/>

        <TextView
            android:id="@+id/title_new_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your new password"
            android:fontFamily="@font/poppins_medium"
            android:textColor="@color/white"
            android:textSize="16dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="157dp" />

        <EditText
            android:id="@+id/edit_new_password"
            android:layout_width="282dp"
            android:layout_height="56dp"
            android:ems="10"
            android:background="@drawable/back_button_profile"
            android:inputType="textPassword"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="185dp"
            android:hint="New password"
            android:textColorHint="@color/gost"
            android:paddingLeft="20dp"
            android:textColor="@color/gost"
            android:textSize="14dp"
            android:fontFamily="@font/poppins_medium"/>

        <Button
            android:id="@+id/button_apply_password"
            android:layout_width="282dp"
            android:layout_height="56dp"
            android:text="Apply"
            android:background="@drawable/border_border_button_password"
            android:backgroundTint="@null"
            android:textSize="18dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="260dp"
            android:textColor="#39260B"
            app:backgroundTint="@null"/>

    </FrameLayout>

    <FrameLayout
        android:id="@+id/delete_acc_fragment"
        android:layout_width="348dp"
        android:layout_height="158dp"
        android:background="@drawable/back_button_checkout"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="160dp">

        <TextView
            android:id="@+id/title_delete_acc_frag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete Account"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/white"
            android:textSize="22dp"
            android:layout_marginTop="23dp"
            android:layout_gravity="center_horizontal"/>
        <TextView
            android:id="@+id/title_descript_delete_acc_frag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Are you sure you want to delete account ?"
            android:fontFamily="@font/poppins"
            android:textColor="@color/text_button"
            android:textSize="15dp"
            android:layout_marginTop="60dp"
            android:layout_gravity="center_horizontal"/>

        <Button
            android:id="@+id/button_yes_delete"
            android:layout_width="79dp"
            android:layout_height="45dp"
            android:text="Yes"
            android:background="@drawable/border_border_button_password"
            android:backgroundTint="@null"
            android:textSize="18dp"
            android:layout_marginLeft="77dp"
            android:layout_marginTop="98dp"
            android:textColor="#39260B"
            app:backgroundTint="@null"/>

        <Button
            android:id="@+id/button_no_delete"
            android:layout_width="79dp"
            android:layout_height="45dp"
            android:text="No"
            android:background="@drawable/back_button_profile"
            android:backgroundTint="@null"
            android:textSize="18dp"
            android:layout_marginRight="77dp"
            android:layout_gravity="right"
            android:layout_marginTop="98dp"
            android:textColor="@color/white"
            app:backgroundTint="@null"/>



    </FrameLayout>




</FrameLayout>