<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Checkout_frag"
    android:background="@color/text_button">

    <TextView
        android:id="@+id/title_frag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checkout"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/white"
        android:textSize="22dp"
        android:layout_marginTop="35dp"
        android:layout_gravity="center_horizontal"/>

    <ImageView
        android:id="@+id/back_button_checkout"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/back_button"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="70dp"/>

    <TextView
        android:id="@+id/title_deliver_address_geo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deliver Address"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="20dp"
        android:layout_marginTop="118dp"
        android:layout_marginLeft="20dp"
        android:layout_gravity="left"/>





    <ImageView
        android:id="@+id/imageView25_geo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="161dp"
        android:layout_marginLeft="20dp"
        android:src="@drawable/icon_geo" />

    <TextView
        android:id="@+id/title_geo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deliver Address"
        android:fontFamily="@font/poppins_semibold"
        android:textColor="@color/white"
        android:textSize="20dp"
        android:layout_marginTop="161dp"
        android:layout_marginLeft="85dp"
        android:layout_gravity="left"/>

    <TextView
        android:id="@+id/title_street_geo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="left"
        android:layout_marginLeft="85dp"
        android:layout_marginTop="190dp"
        android:fontFamily="@font/poppins"
        android:text="000, street super"
        android:textColor="@color/white"
        android:textSize="13dp" />

    <ImageView
        android:id="@+id/imageView26"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="261dp"
        android:layout_marginLeft="20dp"
        android:src="@drawable/icon_card_pay" />

    <TextView
        android:id="@+id/title_card_pay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Payment Method"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="20dp"
        android:layout_marginTop="221dp"
        android:layout_marginLeft="20dp"
        android:layout_gravity="left"/>

    <TextView
        android:id="@+id/title_add_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Card"
        android:fontFamily="@font/poppins_semibold"
        android:textColor="@color/white"
        android:textSize="20dp"
        android:layout_marginTop="261dp"
        android:layout_marginLeft="85dp"
        android:layout_gravity="left"/>

    <TextView
        android:id="@+id/title_credit_or_debit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="left"
        android:layout_marginLeft="85dp"
        android:layout_marginTop="290dp"
        android:fontFamily="@font/poppins"
        android:text="Credit or debit"
        android:textColor="@color/white"
        android:textSize="13dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_change_chekout"
        android:layout_width="75dp"
        android:layout_height="31dp"
        android:layout_marginTop="173dp"
        android:layout_gravity="right"
        android:layout_marginRight="20dp"
        android:fontFamily="@font/poppins_medium"
        android:textAllCaps="false"
        android:background="@drawable/back_button_checkout"
        android:text="Change" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_add_chekout"
        android:layout_width="75dp"
        android:layout_height="31dp"
        android:layout_marginTop="273dp"
        android:layout_marginRight="20dp"
        android:layout_gravity="right"
        android:fontFamily="@font/poppins_medium"
        android:textAllCaps="false"
        android:background="@drawable/back_button_checkout"
        android:text="Add" />

    <TextView
        android:id="@+id/title_product_list"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Product List"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="20dp"
        android:layout_marginTop="335dp"
        android:layout_marginLeft="20dp"
        android:layout_gravity="left"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rc_item_products_checkout"
        android:layout_width="match_parent"
        android:layout_height="375dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginTop="377dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_payment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/back_layout_items"
        android:textAllCaps="false"
        android:layout_marginRight="20dp"
        android:layout_marginLeft="20dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="25dp"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="18dp"
        android:text="Continue Payment" />


</FrameLayout>