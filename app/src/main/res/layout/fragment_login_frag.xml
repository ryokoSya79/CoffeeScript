<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Login_frag">


    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/login_fon"
        android:scaleType="centerCrop"/>

    <ImageView
        android:id="@+id/imageView4"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/shadow_login"
        android:scaleType="centerCrop"/>

    <ImageView
        android:id="@+id/imageView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="81dp"
        android:src="@drawable/logo_non_text" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_semibold"
        android:text="Welcome to Login"
        android:textSize="24dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="146dp"
        android:textColor="@color/white" />

    <EditText
        android:id="@+id/edit_text_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="210dp"
        android:background="@drawable/back_edit_text"
        android:ems="10"
        android:fontFamily="@font/poppins_medium"
        android:hint="E-mail Address"
        android:paddingLeft="20dp"
        android:inputType="textEmailAddress"
        android:textColorHint="@color/text_edit"
        android:textSize="15dp"
        android:textColor="@color/text_edit"/>

    <EditText
        android:id="@+id/edit_text_pass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="280dp"
        android:background="@drawable/back_edit_text"
        android:ems="10"
        android:fontFamily="@font/poppins_medium"
        android:hint="Password"
        android:paddingLeft="20dp"
        android:inputType="textPassword"
        android:textColorHint="@color/text_edit"
        android:textSize="15dp"
        android:textColor="@color/text_edit"/>

    <Button
        android:id="@+id/button_sign_in"
        android:layout_width="350dp"
        android:layout_height="63dp"
        android:text="Sign in"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/text_button"
        android:backgroundTint="@color/button_color"
        android:textSize="20dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="381dp"
        app:cornerRadius="10dp"/>

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/liner_login"
        android:scaleType="centerCrop"
        android:layout_marginTop="490dp"/>

    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Or Login with"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="16dp"
        android:layout_marginTop="478dp"
        android:layout_gravity="center_horizontal"/>

    <ImageView
        android:id="@+id/imageView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/facebook_button"
        android:layout_marginTop="518dp"
        android:layout_marginLeft="20dp"/>

    <ImageView
        android:id="@+id/imageView9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/google_button"
        android:layout_marginTop="518dp"
        android:layout_marginLeft="149dp"/>

    <ImageView
        android:id="@+id/imageView10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/twitch_button"
        android:layout_marginTop="518dp"
        android:layout_marginLeft="272dp"/>

    <TextView
        android:id="@+id/have_acc_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="16dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginRight="30dp"
        android:layout_marginTop="652dp"
        android:text="Don’t have an account ?" />

    <TextView
        android:id="@+id/regist_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/button_color"
        android:fontFamily="@font/poppins_bold"
        android:textSize="16dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginLeft="110dp"
        android:layout_marginTop="652dp"
        android:text="Register" />


</FrameLayout>