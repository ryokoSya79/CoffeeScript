<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Profile_frag"
    android:background="@color/text_button">

    <TextView
        android:id="@+id/title_frag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Profile"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/white"
        android:textSize="22dp"
        android:layout_marginTop="35dp"
        android:layout_gravity="center_horizontal"/>

    <TextView
        android:id="@+id/text_name_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Name"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/white"
        android:textSize="22dp"
        android:layout_marginTop="200dp"
        android:layout_gravity="center_horizontal"/>

    <ImageView
        android:id="@+id/imageView31"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="108dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/image_profile" />

    <View
        android:id="@+id/background_view_order"
        android:layout_width="394dp"
        android:layout_height="50dp"
        android:layout_marginTop="287dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/back_button_profile" />

    <ImageView
        android:id="@+id/icon_order"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="287dp"
        android:layout_marginLeft="30dp"
        android:src="@drawable/icon_orders" />

    <TextView
        android:id="@+id/title_order_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Orders"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="18dp"
        android:layout_marginTop="298dp"
        android:layout_marginLeft="100dp" />

    <ImageView
        android:id="@+id/strelka_order"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right"
        android:layout_marginTop="303dp"
        android:layout_marginRight="30dp"
        android:src="@drawable/icon_strelka" />

    <View
        android:id="@+id/background_view_setting"
        android:layout_width="394dp"
        android:layout_height="50dp"
        android:layout_marginTop="356dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/back_button_profile" />

    <ImageView
        android:id="@+id/icon_setting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="356dp"
        android:layout_marginLeft="30dp"
        android:src="@drawable/icon_setting" />

    <TextView
        android:id="@+id/title_setting_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Setting"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="18dp"
        android:layout_marginTop="367dp"
        android:layout_marginLeft="100dp" />

    <ImageView
        android:id="@+id/strelka_setting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right"
        android:layout_marginTop="372dp"
        android:layout_marginRight="30dp"
        android:src="@drawable/icon_strelka" />

    <View
        android:id="@+id/background_view_policy"
        android:layout_width="394dp"
        android:layout_height="50dp"
        android:layout_marginTop="425dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/back_button_profile" />

    <ImageView
        android:id="@+id/icon_policy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="425dp"
        android:layout_marginLeft="30dp"
        android:src="@drawable/icon_policy" />

    <TextView
        android:id="@+id/title_policy_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Privacy policy"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="18dp"
        android:layout_marginTop="436dp"
        android:layout_marginLeft="100dp" />

    <ImageView
        android:id="@+id/strelka_policy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right"
        android:layout_marginTop="441dp"
        android:layout_marginRight="30dp"
        android:src="@drawable/icon_strelka" />

    <View
        android:id="@+id/background_view_log_out"
        android:layout_width="394dp"
        android:layout_height="50dp"
        android:layout_marginTop="494dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/back_button_profile" />

    <ImageView
        android:id="@+id/icon_logout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="494dp"
        android:layout_marginLeft="30dp"
        android:src="@drawable/icon_log_out" />

    <TextView
        android:id="@+id/title_log_out"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/white"
        android:textSize="18dp"
        android:layout_marginTop="505dp"
        android:layout_marginLeft="100dp" />

    <ImageView
        android:id="@+id/strelka_logout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right"
        android:layout_marginTop="510dp"
        android:layout_marginRight="30dp"
        android:src="@drawable/icon_strelka" />

    <ImageView
        android:id="@+id/shadow_logout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/shadow_password"
        android:scaleType="centerCrop"/>

    <FrameLayout
        android:id="@+id/logout_acc_fragment"
        android:layout_width="348dp"
        android:layout_height="158dp"
        android:background="@drawable/back_button_checkout"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="160dp">

        <TextView
            android:id="@+id/title_delete_acc_frag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/white"
            android:textSize="22dp"
            android:layout_marginTop="23dp"
            android:layout_gravity="center_horizontal"/>
        <TextView
            android:id="@+id/title_descript_delete_acc_frag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Are you sure you want to logout ?"
            android:fontFamily="@font/poppins"
            android:textColor="@color/text_button"
            android:textSize="15dp"
            android:layout_marginTop="60dp"
            android:layout_gravity="center_horizontal"/>

        <Button
            android:id="@+id/button_yes_logout"
            android:layout_width="79dp"
            android:layout_height="45dp"
            android:text="Yes"
            android:background="@drawable/border_border_button_password"
            android:backgroundTint="@null"
            android:textSize="18dp"
            android:layout_marginLeft="77dp"
            android:layout_marginTop="98dp"
            android:textColor="#39260B"
            app:backgroundTint="@null"/>

        <Button
            android:id="@+id/button_no_logout"
            android:layout_width="79dp"
            android:layout_height="45dp"
            android:text="No"
            android:background="@drawable/back_button_profile"
            android:backgroundTint="@null"
            android:textSize="18dp"
            android:layout_marginRight="77dp"
            android:layout_gravity="right"
            android:layout_marginTop="98dp"
            android:textColor="@color/white"
            app:backgroundTint="@null"/>



    </FrameLayout>


</FrameLayout>